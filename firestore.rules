rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas temporales para la etapa de pruebas del MVP, mientras el login
    // real por telefono esta activo (requiere plan Blaze). Permiten leer y
    // escribir ventas y gastos sin autenticacion todavia.
    // IMPORTANTE: antes de tener usuarios reales, esto debe cambiar a reglas
    // que exijan request.auth.uid == resource.data.usuarioId
    match /ventas/{ventaId} {
      allow read, write: if true;
    }
    match /gastos/{gastoId} {
      allow read, write: if true;
    }
  }
}
